# Telegram bot token (@BotFather dan oling)
BOT_TOKEN=8577685040:AAHhEi0vAV8_GXSu830GaFp5JDLBSWE_gn0

# Admin sifatida botni boshqara oladigan Telegram user ID'lar (vergul bilan ajratilgan)
# O'z ID'ingizni bilish uchun @userinfobot ga /start yozing
ADMIN_IDS=8300890171

# Ma'lumotlar bazasi
# Local dev (default): sqlite+aiosqlite:///./phone_bot.db
# Production (Vercel): postgresql+asyncpg://user:password@host:5432/dbname  (masalan Neon yoki Supabase)
DATABASE_URL=sqlite+aiosqlite:///./phone_bot.db

# FSM (admin formalar) holatini saqlash uchun Redis
# Bo'sh bo'lsa -> local MemoryStorage ishlatiladi (faqat polling/bitta jarayon uchun yaroqli)
# Vercel webhook uchun MAJBURIY: masalan Upstash Redis (redis://... yoki rediss://...)
REDIS_URL=

# Webhook rejimi uchun (Vercel'ga deploy qilganda)
# Masalan: https://sizning-domain.vercel.app/api/webhook
WEBHOOK_URL=
# Telegram webhook so'rovlarini tekshirish uchun maxfiy token (ixtiyoriy, lekin tavsiya etiladi)
WEBHOOK_SECRET=

# Narx valyutasi belgisi
CURRENCY=so'm
